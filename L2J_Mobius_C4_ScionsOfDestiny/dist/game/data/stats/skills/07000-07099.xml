	<skill id="7029" levels="4" name="Super Haste">
		<!-- Level 1: Becomes very quick -->
		<!-- Level 2: Becomes very very quick -->
		<!-- Level 3: Really, really gets faster and stronger. -->
		<!-- Level 4: Gives the battle power of two people to one person. -->
		<table name="#amount">1 1 1 1</table>
		<table name="#mAtkSpd">2 3 4 5</table>
		<table name="#pAtk">250 500 750 1500</table>
		<table name="#mAtk">250 500 750 1500</table>
		<table name="#pAtkSpd">2 3 4 5</table>
		<table name="#reuse">0.01 0.01 0.01 0.01</table>
		<table name="#runSpd">2 3 4 5</table>
		<icon>icon.skill7029</icon>
		<operateType>T</operateType>
		<targetType>SELF</targetType>
		<effectPoint>1</effectPoint>
		<magicLevel>1</magicLevel>
		<effects>
			<effect name="Buff">
				<mul stat="pAtkSpd">#pAtkSpd</mul>
				<mul stat="runSpd">#runSpd</mul>
				<mul stat="mAtkSpd">#mAtkSpd</mul>
				<mul stat="pAtk">#pAtk</mul>
				<mul stat="mAtk">#mAtk</mul> <!-- custom -->
				<mul stat="pReuse">#reuse</mul>
				<mul stat="mReuse">#reuse</mul>
				<mul stat="regHp">#amount</mul>
				<mul stat="regMp">#amount</mul>
				<mul stat="maxMp">#amount</mul>
				<mul stat="weightLimit">#amount</mul>
			</effect>
		</effects>
	</skill>
